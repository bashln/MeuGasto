{
  "expo": {
    "name": "MeuGasto",
    "slug": "meugasto",
    "owner": "bashln",
    "version": "0.3.62",
    "scheme": "com.prati.meugasto",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1976d2"
    },
    "ios": {
      "buildNumber": "62",
      "supportsTablet": true,
      "bundleIdentifier": "com.prati.meugasto"
    },
    "android": {
      "versionCode": 62,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1976d2"
      },
      "package": "com.prati.meugasto",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidSigning",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o MeuGasto acesse a câmera para escanear QR Codes de NFC-e."
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-asset",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "a1d6cf32-6e8c-4edc-a0d0-7c979f8104e7"
      }
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/a1d6cf32-6e8c-4edc-a0d0-7c979f8104e7",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": "1.0.0"
  }
}
