{
  "expo": {
    "name": "MeuGasto",
    "slug": "meugasto",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1976d2"
    },
    "ios": {
      "buildNumber": "10",
      "supportsTablet": true,
      "bundleIdentifier": "com.prati.meugasto"
    },
    "android": {
      "versionCode": 10,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1976d2"
      },
      "package": "com.prati.meugasto",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidSigning",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o MeuGasto acesse a câmera para escanear QR Codes de NFC-e."
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-asset",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "58567750-47a6-4955-a5f2-db6032189fc1"
      }
    },
    "updates": {
      "enabled": false
    }
  }
}
