# Supabase Configuration
# Get these values from your Supabase project settings
# https://app.supabase.com/project/_/settings/api

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# NFC-e Scraper API
NFCE_SCRAPER_URL=https://nfce-scraper.herokuapp.com

# Android release signing (used by scripts/android-build-release-local.sh)
# MEUGASTO_STORE_FILE: path relative to mobile/android/app/
MEUGASTO_STORE_FILE=meugasto-release.jks
MEUGASTO_STORE_PASSWORD=your_keystore_password
MEUGASTO_KEY_ALIAS=your_key_alias
MEUGASTO_KEY_PASSWORD=your_key_password
