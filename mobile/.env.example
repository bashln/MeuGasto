# Supabase Configuration
# Get these values from your Supabase project settings
# https://app.supabase.com/project/_/settings/api

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_AUTH_REDIRECT_URL=https://app.example.com/auth/callback

# Android release signing secrets must stay outside the repository workspace.
# Export them in your shell or store them in a file outside the repo and set:
#   MEUGASTO_SIGNING_ENV_FILE=~/.config/meugasto/release-signing.env
